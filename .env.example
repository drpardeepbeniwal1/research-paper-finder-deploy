# ── NVIDIA NIM API Keys (free tier — 20 RPM each = 60 RPM total) ──────────
# Model used: nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_KEY_1=nvapi-xxxxxxxxxxxxxxxxxxxx   # decode agri account
NVIDIA_KEY_2=nvapi-yyyyyyyyyyyyyyyyyyyy   # prdeepbeni account
NVIDIA_KEY_3=nvapi-zzzzzzzzzzzzzzzzzzzz  # agrisearcher account

# ── Backend ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-random-secret-min-32-chars
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
DB_PATH=./data/papers.db

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Optional: CORE API key (free at core.ac.uk — higher rate limits) ────────
CORE_API_KEY=

# ── Optional: NCBI/PubMed API key (free at ncbi.nlm.nih.gov/account) ────────
NCBI_API_KEY=

# ── Optional: Tor SOCKS5 proxy for Google Scholar (host:port) ───────────────
# Run: sudo apt install tor && sudo service tor start
TOR_PROXY=socks5://localhost:9050
